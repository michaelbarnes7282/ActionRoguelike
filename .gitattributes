# Line endings
* text=auto
*.cpp text eol=lf
*.h text eol=lf
*.cs text eol=lf
*.ini text eol=lf
*.json text eol=lf
*.md text eol=lf

# UE file types
*.uasset filter=lfs diff=lfs merge=lfs -text
