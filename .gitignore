# Visual Studio user-specific files
.vs/
.vsconfig

# JetBrains
.idea/

# macOS
.DS_Store

# Compiled object files
*.slo
*.lo
*.o
*.obj

# Precompiled headers
*.gch
*.pch

# Compiled dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# Project files generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.slnx
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.tlog

# Binary files
Binaries/*
Plugins/*/Binaries/*

# Builds
Build/*
Builds/

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Editor-generated config
Saved/*

# Compiled source for the engine
Intermediate/*
Plugins/*/Intermediate/*

# DDC
DerivedDataCache/*

# Temp files
*.tmp